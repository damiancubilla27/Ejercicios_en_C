#include <stdio.h>
#include <stdlib.h>
#define TAM 10

int main(void) {
	setbuf(stdout, NULL);
	int numeros[TAM];

	for(int i=0;i<TAM;i++)
	{
		printf("Ingrese numero: ");
		scanf("%d", &numeros[i]);
	}

	for(int i=0;i<TAM;i++)
	{
		printf("numero: %d", numeros[i]);
	}
	return EXIT_SUCCESS;
}
