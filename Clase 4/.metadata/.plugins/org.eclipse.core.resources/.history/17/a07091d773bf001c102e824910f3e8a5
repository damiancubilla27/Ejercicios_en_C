#include <stdio.h>
#include <stdlib.h>
#define TAM 5

int main(void) {
	setbuf(stdout, NULL);
	int numeros[TAM];
	int numeroMax;
	int numeroMin;
	int ordenMax;
	int ordenMin;

	for (int i = 0; i < TAM; i++)
	{
		printf("Ingresa un numero: ");
		scanf("%d", &numeros[i]);
		if(i==0 || numeros[i]>numeroMax)
		{
			numeroMax=numeros[i];
			ordenMax=i+1;
		}

		if(i==0 || numeros[i]<numeroMin)
		{
			numeroMin=numeros[i];
			ordenMin=i+1;
		}
	}

	for (int i = 0; i < TAM; i++)
	{
		printf("Numero: %d\n", numeros[i]);
	}

	printf("El numero maximo es %d y su orden de ingreso es %d\n", numeroMax, ordenMax);
	printf("El numero minimo es %d y su orden de ingreso es %d\n", numeroMin, ordenMin);
	return EXIT_SUCCESS;
}
