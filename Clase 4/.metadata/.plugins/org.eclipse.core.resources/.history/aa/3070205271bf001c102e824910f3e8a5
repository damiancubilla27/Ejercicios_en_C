	setbuf(stdout, NULL);
	int numeros[TAM];

	for (int i = 0; i < TAM; i++)
	{
		printf("Ingresa un numero: ");
		scanf("%d", &numeros[i]);
	}

	for (int i = 0; i < TAM; i++)
	{
		printf("Numero: %d\n", numeros[i]);
	}

	return EXIT_SUCCESS;
}
